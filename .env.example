# LLM Engineering Playground - Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit your .env file to version control.

# ── LLM API Keys (need at least one) ─────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_TOKEN=hf_...

# ── Model Defaults ────────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini          # cheap default for experiments
EMBEDDING_MODEL=text-embedding-3-small

# ── Vector DB ─────────────────────────────────────────────
# ChromaDB uses local storage by default (no key needed).
# If using a remote Chroma instance:
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Observability (Module 08) ─────────────────────────────
# Langfuse – get keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Redis Cache (Modules 06, 10) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth (Module 10) ──────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
