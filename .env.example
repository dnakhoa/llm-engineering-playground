# Shared LLM Provider
# ───────────────────
# Set ONE provider key below. The course auto-detects which one to use.
# You can also force a provider with LLM_PROVIDER=openai|anthropic|deepseek|grok|qwen|ollama

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek (OpenAI-compatible)
DEEPSEEK_API_KEY=sk-...

# xAI Grok (OpenAI-compatible)
GROK_API_KEY=...

# Alibaba Qwen (OpenAI-compatible)
QWEN_API_KEY=...

# ── Model & Provider Override ─────────────────────────────────
# LLM_PROVIDER=openai        # force provider (auto-detected if omitted)
# LLM_MODEL=gpt-4o-mini      # override default model
#                              # Other models: gpt-5.6, claude-opus-4-8, claude-fable-5
# OPENAI_BASE_URL=http://localhost:11434/v1  # for Ollama or local servers

# ── Module-specific (optional) ────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_HOST=localhost
CHROMA_PORT=8000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
REDIS_URL=redis://localhost:6379
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
